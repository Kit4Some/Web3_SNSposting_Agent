{
  "name": "web3-security-news-agent",
  "version": "1.0.0",
  "description": "Web3 Security News Automation Agent for X (Twitter)",
  "main": "dist-electron/main.js",
  "author": "Web3 News Agent",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "rebuild": "echo No native modules to rebuild",
    "postinstall": "echo No native modules to rebuild",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "electron-store": "^8.1.0",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.344.0",
    "node-schedule": "^2.1.1",
    "openai": "^4.28.0",
    "p-queue": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^6.22.1",
    "rss-parser": "^3.13.0",
    "sql.js": "^1.10.3",
    "twitter-api-v2": "^1.15.2",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^0.0.0",
    "@types/node": "^20.11.19",
    "@types/node-schedule": "^2.1.6",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-squirrel-startup": "^1.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.web3news.agent",
    "productName": "Web3 Security News Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
